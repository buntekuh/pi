{
  "name": "grue-highlight",
  "displayName": "Grue Language",
  "description": "Syntax highlighting for the Grue interactive fiction language",
  "version": "0.1.0",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "grue",
        "aliases": ["Grue", "grue"],
        "extensions": [".grue"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[grue]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 2
      }
    },
    "grammars": [
      {
        "language": "grue",
        "scopeName": "source.grue",
        "path": "./syntaxes/grue.tmLanguage.json"
      }
    ]
  }
}
