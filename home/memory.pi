// memory.pi — demonstrating variable, @ and !
//
// variable name   allocates one cell, pushes its address when named
// addr @          fetch: reads the value stored at addr
// value addr !    store: writes value into addr


// ----------------------------------------------------------------
// 1. Basic read / write
// ----------------------------------------------------------------

variable score

0 score !               // write 0 into score
"score after init: " print
score @ println         // read it back  →  0

42 score !              // write 42
"score after set:  " print
score @ println         // →  42


// ----------------------------------------------------------------
// 2. Incrementing in place
// ----------------------------------------------------------------

score @ 1 + score !     // score = score + 1
"score after +1:   " print
score @ println         // →  43


// ----------------------------------------------------------------
// 3. A handy +! macro (add to variable, like Forth's +!)
// ----------------------------------------------------------------

: +!   -> n addr:   addr @ n + addr ! ;

10 score +!
"score after +10:  " print
score @ println         // →  53


// ----------------------------------------------------------------
// 4. Two variables, swapping their values
// ----------------------------------------------------------------

variable a
variable b

7  a !
13 b !

// swap: read both, write each into the other
a @ b @ -> va vb:
vb a !
va b !

"a after swap: " print   a @ println    // →  13
"b after swap: " print   b @ println    // →  7


// ----------------------------------------------------------------
// 5. Using a variable as a loop counter
// ----------------------------------------------------------------

variable i

0 i !
"counting: " print
while i @ 5 <:
    i @ print " " print
    1 i +!
end
println                  // newline — prints: 0 1 2 3 4


// ----------------------------------------------------------------
// 6. Simulating a two-element array with consecutive variables
// ----------------------------------------------------------------
//
// Pi has no built-in array syntax, but variables are allocated
// at sequential addresses (0, 1, 2, …).  Declaring them together
// and doing address arithmetic gives you a manual array.

variable arr0
variable arr1
variable arr2

100 arr0 !
200 arr1 !
300 arr2 !

// read element at offset 1: arr0's address + 1
"arr[1] = " print
arr0 1 + @ println       // →  200
