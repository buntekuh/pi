#!/bin/bash
TOOLS="$(cd "$(dirname "$0")/.." && pwd)"
exec env \
  PYTHONHOME="$TOOLS/python38-home/usr" \
  PYTHONPATH="$TOOLS/prjxray-snap/opt/prjxray:$TOOLS/prjxray-snap/usr/lib/python3/dist-packages:$TOOLS/prjxray-snap/lib/python3.8/site-packages" \
  LD_LIBRARY_PATH="$TOOLS/lib" \
  "$TOOLS/bin/python3.8" "$TOOLS/prjxray-snap/opt/prjxray/utils/fasm2frames.py" "$@"
